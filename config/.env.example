# AWS Configuration
AWS_REGION=us-west-1
AWS_ACCOUNT_ID=123456789012

# Database (Redshift Serverless)
DB_HOST=workgroup.123456.us-west-1.redshift-serverless.amazonaws.com
DB_NAME=dev
DB_USER=admin
DB_PASSWORD=your-secure-password-here

# Instagram
INSTAGRAM_TOKEN=your-instagram-access-token-here
INSTAGRAM_ACCOUNT=your-instagram-account-id-here

# VPC Configuration
VPC_ID=vpc-xxxxxxxxx
SUBNET1=subnet-xxxxxxxxx
SUBNET2=subnet-xxxxxxxxx
SECURITY_GROUP=sg-xxxxxxxxx

# AWS Resources (generated during setup)
S3_BUCKET=instagram-poster-lambda-packages-xxxxx
SQS_QUEUE_URL=https://sqs.us-west-1.amazonaws.com/xxxxx/instagram-post-queue
SNS_TOPIC_ARN=arn:aws:sns:us-west-1:xxxxx:instagram-poster-alerts
ROLE_ARN=arn:aws:iam::xxxxx:role/InstagramPosterLambdaRole
LAYER_ARN=arn:aws:lambda:us-west-1:xxxxx:layer:instagram-poster-dependencies:1